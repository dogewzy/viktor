# LLM
DEEPSEEK_API_KEY=your-deepseek-api-key
REVIEWER_API_KEY=
REVIEWER_BASE_URL=https://llm.example.com/v1

# DingTalk
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret

# Viktor metadata database
VIKTOR_DB_HOST=127.0.0.1
VIKTOR_DB_PORT=3306
VIKTOR_DB_NAME=viktor
VIKTOR_DB_USER=viktor
VIKTOR_DB_PASSWORD=change-me

# Web auth
VIKTOR_AUTH_SECRET=change-me

# Kubernetes API access, optional
K8S_NAMESPACE=default
K8S_IN_CLUSTER=false
K8S_CONTEXT=
K8S_API_SERVER=
K8S_TOKEN=
K8S_CA_DATA=

# GitLab integration, optional
GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_PRIVATE_TOKEN=
GITLAB_WEBHOOK_SECRET=

# Log service / object storage, optional
ALIYUN_SLS_ENDPOINT=
ALIYUN_SLS_ACCESS_KEY_ID=
ALIYUN_SLS_ACCESS_KEY_SECRET=
ALIYUN_SLS_SECURITY_TOKEN=
VIKTOR_OSS_ACCESS_KEY=
VIKTOR_OSS_SECRET_KEY=
VIKTOR_OSS_ENDPOINT=
VIKTOR_OSS_ENDPOINT_PUBLIC=
VIKTOR_OSS_BUCKET=

# SSH tunnel defaults, optional
SSH_TUNNEL_JUMP_HOST=
SSH_TUNNEL_JUMP_PORT=22
SSH_TUNNEL_USERNAME=
SSH_TUNNEL_PRIVATE_KEY=
